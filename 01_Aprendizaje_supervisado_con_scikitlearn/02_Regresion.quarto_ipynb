       "</table>\n",
       "</div>"
      ],
      "text/plain": [
       "        tv    radio  social_media     sales\n",
       "0  16000.0  6566.23       2907.98  54732.76\n",
       "1  13000.0  9237.76       2409.57  46677.90"
      ]
     },
     "execution_count": 7,
     "metadata": {},
     "output_type": "execute_result"
